{
  "manifest_version": 3,
  "name": "Gryd Lock",
  "version": "0.1.0",
  "description": "Warns before signing a Stellar transaction if the destination looks fraudulent.",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "options_ui": {
    "page": "src/history/index.html",
    "open_in_tab": true
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["mainWorld.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["<all_urls>"]
}
